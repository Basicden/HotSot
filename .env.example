# HotSot — Environment Variables Template
# Copy to .env and fill in values before running docker-compose

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hotsot:hotsot_dev_pass@postgres:5432/hotsot
POSTGRES_DB=hotsot
POSTGRES_USER=hotsot
POSTGRES_PASSWORD=hotsot_dev_pass

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Kafka ────────────────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:29092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ─── Service URLs (for API Gateway) ──────────────────────
ORDER_SERVICE_URL=http://order-service:8001
KITCHEN_SERVICE_URL=http://kitchen-service:8002
SHELF_SERVICE_URL=http://shelf-service:8003
ETA_SERVICE_URL=http://eta-service:8004
NOTIFICATION_SERVICE_URL=http://notification-service:8005
REALTIME_SERVICE_URL=http://realtime-service:8006
ML_SERVICE_URL=http://ml-service:8007
ARRIVAL_SERVICE_URL=http://arrival-service:8008
COMPENSATION_SERVICE_URL=http://compensation-service:8010

# ─── Arrival Service ─────────────────────────────────────
ARRIVAL_RADIUS_M=150
QR_TOKEN_ROTATION_S=30
DEDUP_WINDOW_S=30
PRIORITY_BOOST_AMOUNT=20

# ─── Compensation Service ────────────────────────────────
DELAY_THRESHOLD_MINUTES=15
CREDIT_NOTE_MIN_AMOUNT=50.0
CREDIT_NOTE_MAX_AMOUNT=100.0
SHELF_EXPIRATION_PENALTY_THRESHOLD=3

# ─── ETA Service ─────────────────────────────────────────
MODEL_PATH=/app/models/eta_model.txt

# ─── ML Service ──────────────────────────────────────────
S3_BUCKET=hotsot-ml-data
MODEL_REGISTRY=/app/models

# ─── Notification Service ────────────────────────────────
SMS_PROVIDER=mock

# ─── Auth / JWT ──────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# ─── Docker Registry (for CI/CD) ────────────────────────
DOCKER_REGISTRY=ghcr.io/basicden/hotsot
DOCKER_TAG=latest
K8S_NAMESPACE=hotsot
